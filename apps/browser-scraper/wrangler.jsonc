{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "switch-operator-browser-scraper",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-29",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
  "browser": {
    "binding": "BROWSER",
  },
}
